# ──────────────────────────────────────────────
# OSU RAG ETL Pipeline — Environment Variables
# ──────────────────────────────────────────────
# Copy this file to .env and fill in real values.

# Google GenAI API key (for text-embedding-004)
# Obtain from: https://aistudio.google.com/apikey
GOOGLE_API_KEY=your-google-api-key-here

# Google Cloud Project ID (for Firestore)
# Obtain from: https://console.cloud.google.com
GCP_PROJECT_ID=your-gcp-project-id

# Firestore collection name for vector storage
FIRESTORE_COLLECTION=osu-knowledge

# ── Crawler Settings (used with --crawl flag) ──
# Max depth of link-following from seed URLs (0 = seeds only)
CRAWL_MAX_DEPTH=3
# Hard cap on total pages to crawl
CRAWL_MAX_PAGES=500
# Seconds to wait between requests (politeness)
CRAWL_DELAY=1.0
# Strip query parameters when normalizing URLs (true/false)
CRAWL_STRIP_QUERY=true
