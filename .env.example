# ──────────────────────────────────────────────
# OSU RAG ETL Pipeline — Environment Variables
# ──────────────────────────────────────────────
# Copy this file to .env and fill in real values.

# Google GenAI API key (for text-embedding-004)
# Obtain from: https://aistudio.google.com/apikey
GOOGLE_API_KEY=your-google-api-key-here

# Google Cloud Project ID (for Firestore)
# Obtain from: https://console.cloud.google.com
GCP_PROJECT_ID=your-gcp-project-id

# Firestore collection name for vector storage
FIRESTORE_COLLECTION=osu-knowledge

# ── Crawler Settings (used with --crawl flag) ──
# Max depth of link-following from seed URLs (0 = seeds only)
CRAWL_MAX_DEPTH=3
# Hard cap on total pages to crawl
CRAWL_MAX_PAGES=5000
# Minimum seconds to wait between requests to the same domain
CRAWL_DELAY=1.0
# Random extra seconds added to each delay (0–N); breaks uniform timing that WAFs flag as bots
CRAWL_JITTER=0.5
# Number of parallel worker threads (keep low to avoid 403s; 5 is safe)
CRAWL_MAX_WORKERS=5
# Strip query parameters when normalizing URLs (true/false)
CRAWL_STRIP_QUERY=true
# Minimum word count for a page to have its links followed (thin pages are still recorded)
CRAWL_MIN_WORDS=150
# Set to "false" to disable robots.txt checking entirely
CRAWL_RESPECT_ROBOTS=true
# Comma-separated domains to bypass robots.txt even when CRAWL_RESPECT_ROBOTS=true
CRAWL_ROBOTS_IGNORE_DOMAINS=
# Extra comma-separated URL substring patterns to skip (merged with url_exclusions.txt)
CRAWL_EXCLUDE_PATTERNS=

# ── ETL Settings ──
# Number of parallel embedding/upsert workers
ETL_MAX_WORKERS=10
